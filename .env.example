# Apify credentials — set these in Vercel → Project Settings → Environment Variables
# Never commit the actual .env.local file (it's in .gitignore)

VITE_APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
VITE_APIFY_ACTOR_ID=apify/mudah-search-scraper
VITE_APIFY_SEARCH_URL=https://www.mudah.my/malaysia/cars-for-sale
VITE_APIFY_MAX_ITEMS=500
VITE_APIFY_SCHEDULE_CRON=0 */6 * * *
